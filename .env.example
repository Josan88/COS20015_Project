# Campus Equipment Loan — Environment Configuration
# Copy this file to `.env` and adjust for your local setup.
# `.env` is git-ignored; do not commit credentials.

# Full URL prefix of the remote CouchDB, including any auth and
# per-app database name. The app appends `_students`, `_equipment`,
# and `_loans` to this prefix to build per-table database URLs.
#
# Examples:
#   COUCHDB_URL=http://localhost:5984/campus_equipment_loan2
#   COUCHDB_URL=http://admin:admin@192.168.0.18:5984/campus_equipment_loan2
COUCHDB_URL=http://localhost:5984/campus_equipment_loan2

# Optional override for the local PouchDB storage directory used by
# scripts/seed-couchdb.js. If unset, the seed script falls back to
# ~/.equipment-loan-app/ (the app itself uses Electron's userData
# path on Windows; this env var lets the two agree for testing).
# POUCHDB_DIR=./data
