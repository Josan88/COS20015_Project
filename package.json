{
  "name": "equipment-loan-app",
  "version": "1.0.0",
  "description": "Campus Equipment Loan System",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev":          "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build":        "vite build",
    "electron:dev": "electron .",
    "dist":         "vite build && electron-builder"
  },
  "dependencies": {
    "react":     "^18.3.1",
    "react-dom": "^18.3.1",
    "sqlite3":   "^5.1.6",
    "axios":     "^1.6.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently":         "^8.2.2",
    "electron":             "^31.0.0",
    "electron-builder":     "^24.13.3",
    "vite":                 "^5.4.2",
    "wait-on":              "^7.2.0"
  },
  "build": {
    "appId": "edu.campus.equipment-loan",
    "productName": "Campus Equipment Loan",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png"
    }
  }
}
