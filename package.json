{
  "name": "equipment-loan-app",
  "version": "1.0.0",
  "description": "Campus Equipment Loan System",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "postinstall": "npx install-electron",
    "dev":          "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build":        "vite build",
    "electron:dev": "electron .",
    "dist":         "vite build && electron-builder",
    "seed:couchdb": "node scripts/seed-couchdb.js"
  },
  "dependencies": {
    "react":     "^18.3.1",
    "react-dom": "^18.3.1",
    "sqlite3":   "^6.0.1",
    "axios":     "^1.6.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently":         "^8.2.2",
    "electron":             "^42.4.0",
    "electron-builder":     "^26.15.2",
    "vite":                 "^8.0.16",
    "wait-on":              "^9.0.10"
  },
  "build": {
    "appId": "edu.campus.equipment-loan",
    "productName": "Campus Equipment Loan",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png"
    }
  }
}
